# Aritiq — bring-your-own-key configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in ONE provider's
# key. Aritiq ships no keys of its own; a key is only needed to audit novel
# documents. The bundled examples and the verifier itself need no key.
#
#   cp .env.example .env
#
# --------------------------------------------------------------------------

# Which model provider to use for claim extraction.
# One of: anthropic | openai | gemini | groq
ARITIQ_PROVIDER=anthropic

# Set the key that matches the provider you chose above.
# Leave the others blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional provider-agnostic overrides (checked before the vars above).
# Handy if your key already lives under a different variable name.
#   ARITIQ_API_KEY_VAR  -> name of the env var that holds your key
#   ARITIQ_API_KEY      -> the key value itself
# Example: reuse an existing MY_SECRET without renaming it:
#   ARITIQ_API_KEY_VAR=MY_SECRET
# Or paste the value directly:
#   ARITIQ_API_KEY=sk-...

# Optional: pin a specific model. If unset, a sensible default per provider is
# used (see aritiq/extract/extractor.py). Examples:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o
#   gemini    -> gemini-2.5-flash
#   groq      -> meta-llama/llama-4-scout-17b-16e-instruct
# ARITIQ_EXTRACT_MODEL=

# Optional: where the local FastAPI backend binds (defaults are fine for local).
# ARITIQ_HOST=127.0.0.1
# ARITIQ_PORT=8000
